general {
    colors = true
    interval = 1
}

order += "cpu_usage"
order += "memory"
order += "ethernet _first_"
order += "tztime local"

cpu_usage {
    format = "CPU %usage"
}

memory {
    format = "RAM %percentage_used"
}

ethernet _first_ {
    format_up = "%interface %ip %downspeed %upspeed"
}

tztime local {
    format = "%H:%M"
}
